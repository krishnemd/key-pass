#!/bin/bash

# KeyPass - Quick Password Manager
# Usage: keypass [search_term]
#   keypass           - List all passwords
#   keypass github    - Search and copy password
#   keypass add       - Add new password
#   keypass delete    - Delete password

set -e

# Configuration
VAULT_DIR="$HOME/Library/Application Support/KeyPass"
VAULT_FILE="$VAULT_DIR/vault.enc"
MASTER_PASS_FILE="$VAULT_DIR/.master"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Create vault directory
mkdir -p "$VAULT_DIR"
chmod 700 "$VAULT_DIR"

# Get or set master password (cached for session)
get_master_password() {
    # Check if password cached (expires in 5 minutes)
    if [ -f "$MASTER_PASS_FILE" ]; then
        # Check if file is less than 5 minutes old
        if [ $(($(date +%s) - $(stat -f %m "$MASTER_PASS_FILE"))) -lt 300 ]; then
            MASTER_PASS=$(cat "$MASTER_PASS_FILE")
            return 0
        fi
    fi
    
    # Prompt for password
    echo -ne "${BLUE}Master password: ${NC}" >&2
    read -s MASTER_PASS
    echo "" >&2
    
    if [ -z "$MASTER_PASS" ]; then
        echo -e "${RED}✗ No password provided${NC}" >&2
        exit 1
    fi
    
    # Cache it (secure: 600 permissions)
    echo "$MASTER_PASS" > "$MASTER_PASS_FILE"
    chmod 600 "$MASTER_PASS_FILE"
}

# Decrypt vault
decrypt_vault() {
    if [ ! -f "$VAULT_FILE" ]; then
        touch /tmp/keypass_vault.tmp
        return 0
    fi
    
    if ! openssl enc -aes-256-cbc -d -pbkdf2 -iter 100000 \
        -in "$VAULT_FILE" -out /tmp/keypass_vault.tmp -pass pass:"$MASTER_PASS" 2>/dev/null; then
        echo -e "${RED}✗ Wrong password or corrupted vault${NC}" >&2
        rm -f "$MASTER_PASS_FILE" /tmp/keypass_vault.tmp
        exit 1
    fi
}

# Encrypt vault
encrypt_vault() {
    openssl enc -aes-256-cbc -salt -pbkdf2 -iter 100000 \
        -in /tmp/keypass_vault.tmp -out "$VAULT_FILE" -pass pass:"$MASTER_PASS" 2>/dev/null
    chmod 600 "$VAULT_FILE"
}

# Search passwords (fuzzy)
search_passwords() {
    local search_term="$1"
    
    if [ -z "$search_term" ]; then
        # List all
        cat /tmp/keypass_vault.tmp 2>/dev/null || true
    else
        # Case-insensitive search
        grep -i "$search_term" /tmp/keypass_vault.tmp 2>/dev/null || true
    fi
}

# Show interactive menu and copy password
copy_password_interactive() {
    local search_term="$1"
    
    # Get matching passwords
    local results=$(search_passwords "$search_term")
    
    if [ -z "$results" ]; then
        echo -e "${YELLOW}No passwords found${NC}" >&2
        exit 0
    fi
    
    # Count results
    local count=$(echo "$results" | wc -l | tr -d ' ')
    
    if [ "$count" -eq 1 ]; then
        # Only one result - copy directly
        local name=$(echo "$results" | cut -d'|' -f1)
        local password=$(echo "$results" | cut -d'|' -f2)
        
        echo -n "$password" | pbcopy
        echo -e "${GREEN}✓ Copied '$name'${NC} (clears in 30s)" >&2
        
        # Auto-clear clipboard
        (
            sleep 30
            current=$(pbpaste)
            if [ "$current" = "$password" ]; then
                echo -n "" | pbcopy
                echo -e "${GREEN}✓ Clipboard cleared${NC}" >&2
            fi
        ) &
        
        exit 0
    fi
    
    # Multiple results - show menu
    echo -e "${BLUE}Found $count matches:${NC}" >&2
    echo "" >&2
    
    local index=1
    while IFS='|' read -r name password; do
        echo -e "${BLUE}$index.${NC} $name" >&2
        ((index++))
    done <<< "$results"
    
    echo "" >&2
    echo -ne "${YELLOW}Select [1-$count] or 0 to cancel: ${NC}" >&2
    read choice
    
    if [ "$choice" = "0" ] || ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "$count" ]; then
        echo "Cancelled" >&2
        exit 0
    fi
    
    # Get selected password
    local entry=$(echo "$results" | sed -n "${choice}p")
    local name=$(echo "$entry" | cut -d'|' -f1)
    local password=$(echo "$entry" | cut -d'|' -f2)
    
    # Copy to clipboard
    echo -n "$password" | pbcopy
    echo -e "${GREEN}✓ Copied '$name'${NC} (clears in 30s)" >&2
    
    # Auto-clear clipboard
    (
        sleep 30
        current=$(pbpaste)
        if [ "$current" = "$password" ]; then
            echo -n "" | pbcopy
            echo -e "${GREEN}✓ Clipboard cleared${NC}" >&2
        fi
    ) &
}

# Add new password
add_password() {
    echo -ne "${BLUE}Password name: ${NC}" >&2
    read name
    
    if [ -z "$name" ]; then
        echo -e "${RED}Name cannot be empty${NC}" >&2
        exit 1
    fi
    
    echo -ne "${BLUE}Password: ${NC}" >&2
    read -s password
    echo "" >&2
    
    if [ -z "$password" ]; then
        echo -e "${RED}Password cannot be empty${NC}" >&2
        exit 1
    fi
    
    # Check if exists
    if grep -q "^$name|" /tmp/keypass_vault.tmp 2>/dev/null; then
        echo -ne "${YELLOW}Password '$name' exists. Overwrite? (y/n): ${NC}" >&2
        read confirm
        if [ "$confirm" != "y" ]; then
            exit 0
        fi
        grep -v "^$name|" /tmp/keypass_vault.tmp > /tmp/keypass_vault.tmp.new 2>/dev/null || true
        mv /tmp/keypass_vault.tmp.new /tmp/keypass_vault.tmp
    fi
    
    echo "$name|$password" >> /tmp/keypass_vault.tmp
    encrypt_vault
    
    echo -e "${GREEN}✓ Password saved${NC}" >&2
}

# Delete password
delete_password() {
    local search_term="$1"
    
    local results=$(search_passwords "$search_term")
    
    if [ -z "$results" ]; then
        echo -e "${YELLOW}No passwords found${NC}" >&2
        exit 0
    fi
    
    # Show results
    echo -e "${BLUE}Select password to delete:${NC}" >&2
    echo "" >&2
    
    local index=1
    while IFS='|' read -r name password; do
        echo -e "${BLUE}$index.${NC} $name" >&2
        ((index++))
    done <<< "$results"
    
    local count=$(echo "$results" | wc -l | tr -d ' ')
    echo "" >&2
    echo -ne "${YELLOW}Select [1-$count] or 0 to cancel: ${NC}" >&2
    read choice
    
    if [ "$choice" = "0" ] || ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "$count" ]; then
        echo "Cancelled" >&2
        exit 0
    fi
    
    local entry=$(echo "$results" | sed -n "${choice}p")
    local name=$(echo "$entry" | cut -d'|' -f1)
    
    echo -ne "${RED}Delete '$name'? (y/n): ${NC}" >&2
    read confirm
    
    if [ "$confirm" = "y" ]; then
        grep -v "^$name|" /tmp/keypass_vault.tmp > /tmp/keypass_vault.tmp.new 2>/dev/null || true
        mv /tmp/keypass_vault.tmp.new /tmp/keypass_vault.tmp
        encrypt_vault
        echo -e "${GREEN}✓ Deleted${NC}" >&2
    fi
}

# List all passwords
list_all() {
    if [ ! -s /tmp/keypass_vault.tmp ]; then
        echo "No passwords stored yet"
        exit 0
    fi
    
    local index=1
    while IFS='|' read -r name password; do
        echo "$index. $name"
        ((index++))
    done < /tmp/keypass_vault.tmp
}

# Cleanup
cleanup() {
    rm -f /tmp/keypass_vault.tmp
}
trap cleanup EXIT

# Copy by number (kp 1, kp 2, etc.)
copy_by_number() {
    local num="$1"
    
    if [ ! -s /tmp/keypass_vault.tmp ]; then
        echo -e "${YELLOW}No passwords stored yet${NC}" >&2
        exit 0
    fi
    
    local total=$(wc -l < /tmp/keypass_vault.tmp | tr -d ' ')
    
    if [ "$num" -lt 1 ] || [ "$num" -gt "$total" ]; then
        echo -e "${RED}✗ Invalid number (1-$total)${NC}" >&2
        exit 1
    fi
    
    # Get password at index
    local entry=$(sed -n "${num}p" /tmp/keypass_vault.tmp)
    local name=$(echo "$entry" | cut -d'|' -f1)
    local password=$(echo "$entry" | cut -d'|' -f2)
    
    # Copy to clipboard
    echo -n "$password" | pbcopy
    echo -e "${GREEN}✓ Copied '$name'${NC} (clears in 30s)" >&2
    
    # Auto-clear clipboard
    (
        sleep 30
        current=$(pbpaste)
        if [ "$current" = "$password" ]; then
            echo -n "" | pbcopy
            echo -e "${GREEN}✓ Clipboard cleared${NC}" >&2
        fi
    ) &
}

# Main logic
get_master_password
decrypt_vault

# Check if argument is a number for direct copy
if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
    copy_by_number "$1"
    exit 0
fi

case "${1:-}" in
    add)
        add_password
        ;;
    delete|del|rm)
        delete_password "$2"
        ;;
    list|ls|"")
        list_all
        ;;
    *)
        # Search and copy
        copy_password_interactive "$1"
        ;;
esac
